cat > .gitignore << 'EOF'
# Python virtual environments
venv/

# Environment variables
.env
!.env.template

# Data, models, and images
*.parquet
*.zip
*.npy
*.index
models/
images/

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Python caches
__pycache__/
*.pyc

# IDE and OS-specific files
.vscode/
.idea/
.DS_Store

# Misc
AGENTS.md
*.pth
image_download.log
EOF

git add .gitignore
git commit -m "Fix gitignore: separate AGENTS.md and *.pth, unblock .env.template"
git push